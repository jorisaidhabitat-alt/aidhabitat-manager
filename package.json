{
  "name": "aid'habitat-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:frontend\"",
    "dev:api": "node server/index.mjs",
    "dev:frontend": "vite",
    "build": "vite build",
    "build:pwa": "bash aid_habitat_app/tool/build_web.sh",
    "build:all": "npm run build && npm run build:pwa",
    "check:critical": "node tools/check-critical-flows.mjs",
    "backup:verify": "node tools/verify-nocodb-backup.mjs",
    "backup:restore-plan": "node tools/plan-nocodb-restore.mjs",
    "storage:readiness": "node tools/analyze-object-storage-readiness.mjs",
    "staging:snapshot": "node tools/create-staging-snapshot.mjs",
    "staging:export-schema-plan": "node tools/export-nocodb-schema-plan.mjs",
    "staging:export-import-batches": "node tools/export-nocodb-import-batches.mjs",
    "staging:import-batches": "node tools/import-nocodb-batches.mjs",
    "commercial:preflight": "node tools/run-commercial-readiness-check.mjs",
    "cleanup:artifacts": "node tools/cleanup-local-artifacts.mjs",
    "nocodb:api-audit": "node tools/audit-nocodb-api-usage.mjs",
    "secrets:audit": "node tools/audit-env-secrets.mjs",
    "release:web-check": "node tools/check-web-release.mjs",
    "release:live-check": "node tools/check-live-stack.mjs",
    "release:ci-check": "node tools/check-github-actions-head.mjs",
    "release:smoke": "node tools/run-release-smoke.mjs",
    "test:pdf": "node tools/generate-test-report.mjs",
    "test:flutter": "bash aid_habitat_app/tool/test_safely.sh",
    "start": "node server/index.mjs",
    "nocodb:bootstrap-mobile-schema": "node scripts/bootstrapNocodbMobileSchema.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "dexie": "^4.4.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.556.0",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "express-rate-limit": "^8.5.2",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.23",
    "ip-address": "^10.2.0",
    "path-to-regexp": "^8.4.2",
    "qs": "^6.15.2"
  }
}
