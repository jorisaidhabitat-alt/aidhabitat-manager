<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconFile</key>
	<string></string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>$(PRODUCT_COPYRIGHT)</string>
	<key>NSMainNibFile</key>
	<string>MainMenu</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- ====================================================== -->
	<!-- Permissions macOS (NSUsageDescriptions)                 -->
	<!-- Mac App Store rejette toute app qui appelle ces APIs    -->
	<!-- sans purpose string, comme iOS.                         -->
	<!-- ====================================================== -->
	<key>NSCameraUsageDescription</key>
	<string>Aid&apos;Habitat utilise l&apos;appareil photo pour prendre des photos du logement, des sanitaires et des éléments d&apos;accessibilité pendant la visite à domicile.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Aid&apos;Habitat accède à votre photothèque pour ajouter des photos existantes au dossier du bénéficiaire.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Aid&apos;Habitat enregistre les rapports PDF et les photos exportées dans votre photothèque, à votre demande.</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>Aid&apos;Habitat accède au dossier Documents pour importer ou enregistrer des fichiers liés au dossier du bénéficiaire.</string>
	<key>NSDownloadsFolderUsageDescription</key>
	<string>Aid&apos;Habitat enregistre les rapports PDF générés dans votre dossier Téléchargements.</string>

	<!-- Catégorie Mac App Store -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.medical</string>

	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- `NSAllowsArbitraryLoadsInWebContent` : permet à toutes les WebViews
		     (WKWebView) de charger des URLs que la policy ATS rejetterait
		     normalement — sans affaiblir les requêtes HTTP directes du reste
		     de l'app. C'est la clé recommandée par Apple pour les apps qui
		     embarquent un navigateur. -->
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
		<!-- Exception ciblée pour les sous-domaines anah.gouv.fr au cas où
		     la policy se durcirait dans le futur. -->
		<key>NSExceptionDomains</key>
		<dict>
			<key>anah.gouv.fr</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.0</string>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
