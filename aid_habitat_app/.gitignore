app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Vercel build (clones Flutter SDK into ./flutter on the build image)
/flutter/
.vercel/

# sqflite_common_ffi_web: the shared worker + WASM bundle is committed
# (see tool/build_web.sh for details). Re-run `dart run
# sqflite_common_ffi_web:setup` and re-commit when you bump the
# sqflite_common_ffi_web dependency.
#/web/sqflite_sw.js
#/web/sqlite3.wasm
