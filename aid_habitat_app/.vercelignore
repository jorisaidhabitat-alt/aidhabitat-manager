# Flutter PWA project (aid-habitat-app on Vercel).
# Only the Dart source + web/ assets + pubspec are needed — Flutter clones
# its own SDK and regenerates all the platform folders during the build.

.git
.vercel

# Build outputs & caches (regenerated by vercel-build.sh + flutter build)
.dart_tool
.pub-cache
build
.flutter-plugins
.flutter-plugins-dependencies
flutter

# Native platform folders — not needed for web build (Flutter spawns clean
# ones from the SDK anyway, and they're the biggest non-build offenders).
ios
android
macos
windows
linux

# IDE / OS noise
*.iml
*.log
.DS_Store
node_modules
