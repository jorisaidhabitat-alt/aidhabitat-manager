<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Aid&apos;Habitat</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>aid_habitat_app</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- ====================================================== -->
	<!-- Permissions (NSUsageDescriptions)                       -->
	<!-- Apple rejette toute app qui appelle ces APIs sans       -->
	<!-- description "purpose string" — la pop-up système        -->
	<!-- système l'affiche à l'utilisateur lors du 1er accès.   -->
	<!-- ====================================================== -->

	<!-- image_picker (camera) : prise de photo VAD du logement / sanitaires -->
	<key>NSCameraUsageDescription</key>
	<string>Aid&apos;Habitat utilise l&apos;appareil photo pour vous permettre de prendre des photos du logement, des sanitaires et des éléments d&apos;accessibilité pendant la visite à domicile. Ces photos sont attachées au dossier du bénéficiaire et insérées dans le rapport PDF généré.</string>

	<!-- image_picker (gallery) + file_picker : import depuis la photothèque -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Aid&apos;Habitat accède à votre photothèque pour vous permettre d&apos;ajouter des photos existantes (logement, sanitaires, plans) au dossier du bénéficiaire.</string>

	<!-- share_plus + open_filex : sauvegarde de PDF / photos dans la photothèque -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Aid&apos;Habitat enregistre les rapports PDF et les photos exportées dans votre photothèque, à votre demande explicite.</string>

	<!-- file_picker : accès aux fichiers locaux (Documents) -->
	<key>NSDocumentsFolderUsageDescription</key>
	<string>Aid&apos;Habitat accède à votre dossier Documents pour importer ou enregistrer des fichiers liés au dossier du bénéficiaire (rapports PDF, justificatifs).</string>

	<!-- ====================================================== -->
	<!-- Export Compliance                                       -->
	<!-- "false" = on n&apos;utilise QUE de la crypto standard    -->
	<!-- exemptée (HTTPS/TLS via NSURLSession). Évite le         -->
	<!-- formulaire d&apos;encryption export à chaque build       -->
	<!-- TestFlight / App Store Connect.                         -->
	<!-- ====================================================== -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- ====================================================== -->
	<!-- App Transport Security                                  -->
	<!-- HTTPS-only. Aucune exception. NocoDB et le backend      -->
	<!-- Aid&apos;Habitat sont servis en TLS uniquement.            -->
	<!-- ====================================================== -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>

	<!-- ====================================================== -->
	<!-- iPad multi-tasking : Split View + Slide Over            -->
	<!-- Apple privilégie les apps qui supportent le             -->
	<!-- multi-fenêtre iPadOS. Activé par défaut chez Flutter.  -->
	<!-- ====================================================== -->
	<key>UIRequiresFullScreen</key>
	<false/>

	<!-- url_launcher : autorise les schémes utilisés (mailto, tel, https) -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>https</string>
		<string>http</string>
		<string>mailto</string>
		<string>tel</string>
		<string>sms</string>
	</array>

	<!-- ====================================================== -->
	<!-- Catégorie App Store (visible dans Settings → Storage    -->
	<!-- et utilisée par la fiche App Store Connect).            -->
	<!-- "medical" convient pour une app métier ergothérapie.    -->
	<!-- Liste : https://developer.apple.com/library/archive/    -->
	<!--   documentation/General/Reference/                       -->
	<!--   InfoPlistKeyReference/Articles/LaunchServicesKeys.html -->
	<!-- ====================================================== -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.medical</string>

	<!-- ====================================================== -->
	<!-- iPadOS Multi-Window (Split View / Stage Manager)        -->
	<!-- Active officiellement le support multi-fenêtre iPad —   -->
	<!-- bonus pour la review Apple sur les apps métier iPad.    -->
	<!-- ====================================================== -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict/>
	</dict>
</dict>
</plist>
